# Backend
# Default if unset: postgresql+psycopg://damm:damm@localhost:5432/damm
DATABASE_URL=postgresql+psycopg://damm:damm@localhost:5432/damm

# Comma-separated frontend origins allowed to call the API.
# Defaults already include localhost:3000, localhost:3001, optidamm.ink, and www.optidamm.ink.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional regex for preview deployments, for example Vercel preview URLs.
ALLOWED_ORIGIN_REGEX=

# Set to 1/true/yes only when you want the backend to seed data on startup.
SEED_DATABASE_ON_STARTUP=false


# Copilot: Gemini
# Recommended for this app unless you specifically need Vertex AI.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash

# Optional aliases also accepted by the backend.
GOOGLE_API_KEY=
GOOGLE_CLOUD_API_KEY=


# Copilot: Vertex AI on Google Cloud
# Use this instead of GEMINI_API_KEY only when deploying through Google Cloud IAM/Vertex.
# Provide a valid bearer token, for example from workload identity or `gcloud auth print-access-token`.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
VERTEX_AI_ACCESS_TOKEN=

# Optional aliases also accepted by the backend.
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=
GOOGLE_CLOUD_ACCESS_TOKEN=


# Frontend
# Preferred backend base URL for all API calls.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Legacy fallback. Leave empty unless an old deployment still uses it.
NEXT_PUBLIC_SIM_API=
